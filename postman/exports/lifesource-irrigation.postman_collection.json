                },
                {
                  "key": "next",
                  "value": "{{nextPath}}",
                  "description": "Template forms send this to control redirect destination.",
                  "disabled": false
                },
                {
                  "key": "csrfmiddlewaretoken",
                  "value": "{{csrfToken}}",
                  "description": "Optional token when testing with CSRF enabled.",
                  "disabled": false
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is redirect or CSRF rejection\", function () {",
                  "  pm.expect([302, 403]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"Redirect respects next path when request is accepted\", function () {",
                  "  if (pm.response.code === 302) {",
                  "    const location = pm.response.headers.get(\"Location\") || \"\";",
                  "    pm.expect(location).to.match(/^\\//);",
                  "  } else {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "newsletter subscribe ajax post",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/newsletter/subscribe/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              },
              {
                "key": "X-Requested-With",
                "value": "XMLHttpRequest"
              },
              {
                "key": "X-CSRFToken",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "email",
                  "value": "max@example.com",
                  "disabled": false
                },
                {
                  "key": "csrfmiddlewaretoken",
                  "value": "{{csrfToken}}",
                  "disabled": false
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is JSON success or CSRF rejection\", function () {",
                  "  pm.expect([200, 403]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"JSON body has success and message when request is accepted\", function () {",
                  "  if (pm.response.code === 200) {",
                  "    const responseBody = pm.response.json();",
                  "    pm.expect(responseBody).to.have.property(\"success\");",
                  "    pm.expect(responseBody).to.have.property(\"message\");",
                  "  } else {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        }
