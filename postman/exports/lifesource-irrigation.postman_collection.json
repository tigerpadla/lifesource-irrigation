    {
      "name": "Forms",
      "item": [
        {
          "name": "contact form submit",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/contact/",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "first_name",
                  "value": "Max",
                  "disabled": false
                },
                {
                  "key": "last_name",
                  "value": "Tester",
                  "disabled": false
                },
                {
                  "key": "email",
                  "value": "max@example.com",
                  "disabled": false
                },
                {
                  "key": "phone",
                  "value": "(212) 555-0123",
                  "disabled": false
                },
                {
                  "key": "services_needed",
                  "value": "irrigation",
                  "description": "Repeat this key to submit multiple services.",
                  "disabled": false
                },
                {
                  "key": "services_needed",
                  "value": "lighting",
                  "disabled": false
                },
                {
                  "key": "referral_source",
                  "value": "google",
                  "description": "Allowed values: google, referral, returning, social, other.",
                  "disabled": false
                },
                {
                  "key": "message",
                  "value": "Interested in irrigation and lighting for a rooftop terrace project.",
                  "disabled": false
                },
                {
                  "key": "csrfmiddlewaretoken",
                  "value": "{{csrfToken}}",
                  "description": "Optional token when testing with CSRF enabled.",
                  "disabled": false
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is redirect or CSRF rejection\", function () {",
                  "  pm.expect([302, 403]).to.include(pm.response.code);",
                  "});",
                  "pm.test(\"Redirect target is contact success when request is accepted\", function () {",
                  "  if (pm.response.code === 302) {",
                  "    const location = pm.response.headers.get(\"Location\") || \"\";",
                  "    pm.expect(location).to.match(/\\/contact\\/success\\/?$/);",
                  "  } else {",
                  "    pm.expect(pm.response.code).to.eql(403);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
